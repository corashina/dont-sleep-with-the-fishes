{
  "name": "dont-sleep-with-the-fishes",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "models:fetch:items": "powershell -ExecutionPolicy Bypass -File scripts/fetch-item-models.ps1",
    "models:fetch:ship": "powershell -ExecutionPolicy Bypass -File scripts/fetch-ship-furniture.ps1",
    "models:fetch": "npm run models:fetch:items && npm run models:fetch:ship",
    "models:check:items": "node scripts/check-item-models.mjs",
    "models:check:ship": "node scripts/check-ship-furniture.mjs",
    "models:check": "npm run models:check:items && npm run models:check:ship"
  },
  "dependencies": {
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.4.1",
    "@gltf-transform/core": "^4.4.1",
    "@gltf-transform/extensions": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "@types/three": "^0.180.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.0",
    "vite": "^7.1.0",
    "vitest": "^3.2.0"
  }
}
